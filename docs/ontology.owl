        <rdfs:comment xml:lang="en">Links a state definition to a structural item.</rdfs:comment>
        <rdfs:label xml:lang="en">belongs to item</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/ssco/bfi#consistsOf -->


    <owl:ObjectProperty rdf:about="https://w3id.org/ssco/bfi#consistsOf">
