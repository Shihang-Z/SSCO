     xmlns:vann="http://purl.org/vocab/vann/"
     xmlns:terms="http://purl.org/dc/terms/">
    <owl:Ontology rdf:about="https://w3id.org/ssco">
        <owl:versionIRI rdf:resource="https://w3id.org/ssco/0.1.0"/>
        <terms:alternative xml:lang="en">SSCO</terms:alternative>
        <terms:bibliographicCitation xml:lang="en">Zhang, S.; Zhang, S.; Wu, Z. Structural Sustainability Compliance Ontology (SSCO), version 0.1.0, 2026.</terms:bibliographicCitation>
        <terms:contributor xml:lang="en">Chao Wang, State Key Laboratory of Hydraulic Engineering Intelligent Construction and Operation, Tianjin University</terms:contributor>
        <terms:contributor xml:lang="en">Chen Zhu, Power Construction Corporation of China</terms:contributor>
        <terms:contributor xml:lang="en">Xiaohua Wang, State Key Laboratory of Hydraulic Engineering Intelligent Construction and Operation, Tianjin University</terms:contributor>
        <terms:contributor xml:lang="en">Zhiyong Jiang, China Water Resources Beifang Investigation, Design and Research Co. Ltd.</terms:contributor>
        <terms:creator xml:lang="en">Sherong Zhang, State Key Laboratory of Hydraulic Engineering Intelligent Construction and Operation, Tianjin University</terms:creator>
        <terms:creator xml:lang="en">Shihang Zhang, State Key Laboratory of Hydraulic Engineering Intelligent Construction and Operation, Tianjin University</terms:creator>
        <terms:creator xml:lang="en">Zhengqiao Wu, China Water Resources Beifang Investigation, Design and Research Co. Ltd.</terms:creator>
        <terms:description xml:lang="en">An all-in-one publication version of the Structural Sustainability Compliance Ontology, integrating the SSCO-Core, SSCO-BFI, and SSCO-SCC modules.</terms:description>
        <terms:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2026-03-15</terms:issued>
        <terms:license rdf:resource="https://creativecommons.org/licenses/by/4.0/"/>
        <terms:modified rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2026-03-16</terms:modified>
        <terms:rights xml:lang="en">Copyright © 2026 Authors</terms:rights>
        <terms:title xml:lang="en">Structural Sustainability Compliance Ontology</terms:title>
        <vann:preferredNamespacePrefix>ssco</vann:preferredNamespacePrefix>
        <vann:preferredNamespaceUri>https://w3id.org/ssco#</vann:preferredNamespaceUri>
        <rdfs:label xml:lang="en">Structural Sustainability Compliance Ontology</rdfs:label>
        <owl:versionInfo>0.1.0</owl:versionInfo>
        <foaf:homepage rdf:resource="https://w3id.org/ssco"/>
    </owl:Ontology>
    


