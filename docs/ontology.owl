        <rdfs:range rdf:resource="https://w3id.org/ssco/bfi#AnalysisState"/>
        <rdfs:comment xml:lang="en">Links a task to a final analysis state.</rdfs:comment>
        <rdfs:label xml:lang="en">has final state</rdfs:label>
    </owl:ObjectProperty>
    


