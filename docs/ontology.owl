    <!-- https://w3id.org/ssco/bfi#allocatesResource -->


    <owl:ObjectProperty rdf:about="https://w3id.org/ssco/bfi#allocatesResource">
        <rdfs:domain rdf:resource="https://w3id.org/ssco/bfi#Control"/>
        <rdfs:range rdf:resource="https://w3id.org/ssco/bfi#Resource"/>
        <rdfs:comment xml:lang="en">Links a control to a resource.</rdfs:comment>
        <rdfs:label xml:lang="en">allocates resource</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/ssco/bfi#appliesInStep -->


    <owl:ObjectProperty rdf:about="https://w3id.org/ssco/bfi#appliesInStep">
        <rdfs:domain rdf:resource="https://w3id.org/ssco/bfi#Constraint"/>
        <rdfs:range rdf:resource="https://w3id.org/ssco/bfi#AnalysisStep"/>
        <rdfs:comment xml:lang="en">Links a constraint to an analysis step.</rdfs:comment>
        <rdfs:label xml:lang="en">applies in step</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/ssco/bfi#appliesToAnalysisState -->


    <owl:ObjectProperty rdf:about="https://w3id.org/ssco/bfi#appliesToAnalysisState">
        <rdfs:domain rdf:resource="https://w3id.org/ssco/bfi#StateDefinition"/>
        <rdfs:range rdf:resource="https://w3id.org/ssco/bfi#AnalysisState"/>
