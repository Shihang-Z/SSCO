        <rdfs:range rdf:resource="https://w3id.org/ssco/bfi#SpatialStructureElement"/>
        <rdfs:comment xml:lang="en">Links a project to a spatial structure element.</rdfs:comment>
        <rdfs:label xml:lang="en">contains spatial structure element</rdfs:label>
    </owl:ObjectProperty>
    


