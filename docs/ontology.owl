        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">Specifies the technical or functional assessment method used to establish a functional or technical performance value.</rdfs:comment>
        <rdfs:label xml:lang="en">technical assessment method</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/ssco/scc#thresholdUnit -->


    <owl:DatatypeProperty rdf:about="https://w3id.org/ssco/scc#thresholdUnit">
        <rdfs:domain rdf:resource="https://w3id.org/ssco/scc#ComplianceCriterion"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">Specifies the local unit of a threshold value when an explicit value-level unit needs to override or supplement the project unit specification.</rdfs:comment>
        <rdfs:label xml:lang="en">threshold unit</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/ssco/scc#thresholdValue -->


    <owl:DatatypeProperty rdf:about="https://w3id.org/ssco/scc#thresholdValue">
        <rdfs:domain rdf:resource="https://w3id.org/ssco/scc#ComplianceCriterion"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
        <rdfs:comment xml:lang="en">Specifies the scalar threshold used in a compliance criterion for comparison.</rdfs:comment>
        <rdfs:label xml:lang="en">threshold value</rdfs:label>
    </owl:DatatypeProperty>
    


