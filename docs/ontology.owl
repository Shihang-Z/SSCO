        <rdfs:range rdf:resource="https://w3id.org/ssco/bfi#SpatialStructureElement"/>
        <rdfs:comment xml:lang="en">Defines recursive containment among spatial structure elements.</rdfs:comment>
        <rdfs:label xml:lang="en">contains substructure</rdfs:label>
    </owl:ObjectProperty>
    


