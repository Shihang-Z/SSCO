@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix vann: <http://purl.org/vocab/vann/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix sscore: <https://w3id.org/ssco/core#> .
@prefix sscobfi: <https://w3id.org/ssco/bfi#> .
@prefix sscoscc: <https://w3id.org/ssco/scc#> .

<https://w3id.org/ssco/alignment/LOINAlignment> a owl:Ontology ;
  dcterms:title "SSCO alignment module for LOIN"@en ;
  dcterms:description "Alignment axioms connecting SSCO-SCC requirement and criterion constructs to the Level of Information Need (LOIN) ontology."@en ;
  dcterms:created "2026-03-19"^^xsd:date ;
  dcterms:creator "Shihang Zhang"@en ;
  owl:versionInfo "0.1.0" ;
  vann:preferredNamespacePrefix "LOINAlignment" ;
  vann:preferredNamespaceUri "https://w3id.org/ssco/alignment/LOINAlignment" ;
  owl:imports <https://w3id.org/ssco> ,
    <https://w3id.org/loin> .

@prefix loin: <https://w3id.org/loin#> .

sscoscc:ComplianceRequirement skos:relatedMatch loin:LevelOfInformationNeed .
sscoscc:ComplianceCriterion skos:relatedMatch loin:Specification .
sscoscc:Benchmark skos:relatedMatch loin:AlphanumericalInformation .
sscoscc:Performance skos:relatedMatch loin:AlphanumericalInformation .

sscoscc:hasCriterion skos:relatedMatch loin:hasSpecification .
