@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix vann: <http://purl.org/vocab/vann/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix sscore: <https://w3id.org/ssco/core#> .
@prefix sscobfi: <https://w3id.org/ssco/bfi#> .
@prefix sscoscc: <https://w3id.org/ssco/scc#> .

<https://w3id.org/ssco/alignment/bcfOWLAlignment> a owl:Ontology ;
  dcterms:title "SSCO alignment module for bcfOWL"@en ;
  dcterms:description "Alignment axioms connecting SSCO-SCC nonconformity and review-related concepts to bcfOWL issue-tracking constructs such as topics, comments, viewpoints, and project-level coordination records."@en ;
  dcterms:created "2026-03-19"^^xsd:date ;
  dcterms:creator "Shihang Zhang"@en ;
  owl:versionInfo "0.1.0" ;
  vann:preferredNamespacePrefix "bcfOWLAlignment" ;
  vann:preferredNamespaceUri "https://w3id.org/ssco/alignment/bcfOWLAlignment" ;
  owl:imports <https://w3id.org/ssco> ,
    <http://lbd.arch.rwth-aachen.de/bcfOWL> .

@prefix bcfOWL: <http://lbd.arch.rwth-aachen.de/bcfOWL#> .

sscoscc:Nonconformity skos:closeMatch bcfOWL:Topic .
sscoscc:ComplianceCheck skos:relatedMatch bcfOWL:Topic .
sscoscc:ComplianceResult skos:relatedMatch bcfOWL:Comment .

sscoscc:reportsNonconformity skos:relatedMatch bcfOWL:hasTopic .
sscoscc:evidenceReference skos:relatedMatch bcfOWL:hasViewpoint .
sscoscc:nonconformityText skos:closeMatch bcfOWL:hasDescription .
sscoscc:checkDateTime skos:relatedMatch bcfOWL:hasCreationDate .
