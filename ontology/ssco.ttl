@prefix ssco: <https://w3id.org/ssco#> .
@prefix sscore: <https://w3id.org/ssco/core#> .
@prefix sscobfi: <https://w3id.org/ssco/bfi#> .
@prefix sscoscc: <https://w3id.org/ssco/scc#> .
@prefix owl:  <http://www.w3.org/2002/07/owl#> .
@prefix rdf:  <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd:  <http://www.w3.org/2001/XMLSchema#> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix vann: <http://purl.org/vocab/vann/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .

<https://w3id.org/ssco> a owl:Ontology ;
    dcterms:title "Structural Sustainability Compliance Ontology"@en ;
    dcterms:alternative "SSCO"@en ;
    dcterms:description "An all-in-one publication version of the Structural Sustainability Compliance Ontology, integrating the SSCO-Core, SSCO-BFI, and SSCO-SCC modules."@en ;
    dcterms:creator "Shihang Zhang, State Key Laboratory of Hydraulic Engineering Intelligent Construction and Operation, Tianjin University"@en ;
    dcterms:creator "Sherong Zhang, State Key Laboratory of Hydraulic Engineering Intelligent Construction and Operation, Tianjin University"@en ;
    dcterms:creator "Zhengqiao Wu, China Water Resources Beifang Investigation, Design and Research Co. Ltd."@en ;
    dcterms:contributor "Chao Wang, State Key Laboratory of Hydraulic Engineering Intelligent Construction and Operation, Tianjin University"@en ;
    dcterms:contributor "Zhiyong Jiang, China Water Resources Beifang Investigation, Design and Research Co. Ltd."@en ;
    dcterms:contributor "Xiaohua Wang, State Key Laboratory of Hydraulic Engineering Intelligent Construction and Operation, Tianjin University"@en ;
    dcterms:contributor "Chen Zhu, Power Construction Corporation of China"@en ;
    dcterms:issued "2026-03-15"^^xsd:date ;
    dcterms:modified "2026-03-16"^^xsd:date ;
    dcterms:license <https://creativecommons.org/licenses/by/4.0/> ;
    dcterms:rights "Copyright © 2026 Authors"@en ;
    dcterms:bibliographicCitation "Zhang, S.; Zhang, S.; Wu, Z. Structural Sustainability Compliance Ontology (SSCO), version 0.1.0, 2026."@en ;
    owl:versionInfo "0.1.0" ;
    owl:versionIRI <https://w3id.org/ssco/0.1.0> ;
    rdfs:label "Structural Sustainability Compliance Ontology"@en ;
    vann:preferredNamespacePrefix "ssco" ;
    vann:preferredNamespaceUri "https://w3id.org/ssco#" ;
    foaf:homepage <https://w3id.org/ssco> .

#################################################################
# SSCO-Core classes
#################################################################

sscore:Project a owl:Class ;
    rdfs:label "Project"@en ;
    skos:prefLabel "Project"@en ;
    rdfs:comment "A project context that contains structural, analysis, classification, objective, unit, and compliance-related information."@en ;
    dcterms:source "ISO 16739-1:2024, IfcProject."@en .

sscore:Objective a owl:Class ;
    rdfs:label "Objective"@en ;
    skos:prefLabel "Objective"@en ;
    rdfs:comment "A project objective to be measured by one or more metrics."@en ;
    dcterms:source "ISO 16739-1:2024, IfcObjective."@en .

sscore:Metric a owl:Class ;
    rdfs:label "Metric"@en ;
    skos:prefLabel "Metric"@en ;
    rdfs:comment "A measurable quantity used to operationalize an indicator and assess an objective."@en ;
    dcterms:source "ISO 16739-1:2024, IfcMetric."@en .

sscore:Classification a owl:Class ;
    rdfs:label "Classification"@en ;
    skos:prefLabel "Classification"@en ;
    rdfs:comment "A classification system or taxonomy used by the project."@en ;
    dcterms:source "ISO 16739-1:2024, IfcClassification."@en .

sscore:ClassificationReference a owl:Class ;
    rdfs:label "Classification Reference"@en ;
    skos:prefLabel "Classification Reference"@en ;
    rdfs:comment "A reference that links a structural element to a classification entry."@en ;
    dcterms:source "ISO 16739-1:2024, IfcClassificationReference."@en .


sscore:UnitSpecification a owl:Class ;
    rdfs:label "Unit Specification"@en ;
    skos:prefLabel "Unit Specification"@en ;
    rdfs:comment "A specification that defines the default units used for quantitative values within a project context."@en ;
    dcterms:source "ISO 16739-1:2024, IfcUnitAssignment."@en .

sscobfi:Process a owl:Class ;
    rdfs:label "Process"@en ;
    skos:prefLabel "Process"@en ;
    rdfs:comment "A construction or engineering process associated with a spatial or structural context."@en ;
    dcterms:source "ISO 16739-1:2024, IfcProcess."@en .

sscobfi:Task a owl:Class ;
    rdfs:label "Task"@en ;
    skos:prefLabel "Task"@en ;
    rdfs:comment "A task within a process."@en ;
    dcterms:source "ISO 16739-1:2024, IfcTask."@en .

sscobfi:Control a owl:Class ;
    rdfs:label "Control"@en ;
    skos:prefLabel "Control"@en ;
    rdfs:comment "A control that governs task execution and may allocate resources."@en ;
    dcterms:source "ISO 16739-1:2024, IfcControl."@en .

sscobfi:Resource a owl:Class ;
    rdfs:label "Resource"@en ;
    skos:prefLabel "Resource"@en ;
    rdfs:comment "A generic resource consumed or allocated in a task."@en ;
    dcterms:source "ISO 16739-1:2024, IfcResource."@en .

sscobfi:MaterialResource a owl:Class ;
    rdfs:subClassOf sscobfi:Resource ;
    rdfs:label "Material Resource"@en ;
    skos:prefLabel "Material Resource"@en ;
    rdfs:comment "A material resource used by a task or process."@en ;
    dcterms:source "ISO 16739-1:2024, material resource concepts."@en .

sscobfi:LaborResource a owl:Class ;
    rdfs:subClassOf sscobfi:Resource ;
    rdfs:label "Labor Resource"@en ;
    skos:prefLabel "Labor Resource"@en ;
    rdfs:comment "A labor resource used by a task or process."@en ;
    dcterms:source "ISO 16739-1:2024, labor resource concepts."@en .

sscobfi:EquipmentResource a owl:Class ;
    rdfs:subClassOf sscobfi:Resource ;
    rdfs:label "Equipment Resource"@en ;
    skos:prefLabel "Equipment Resource"@en ;
    rdfs:comment "An equipment resource used by a task or process."@en ;
    dcterms:source "ISO 16739-1:2024, construction equipment resource concepts."@en .

sscobfi:ScheduleControl a owl:Class ;
    rdfs:subClassOf sscobfi:Control ;
    rdfs:label "Schedule Control"@en ;
    skos:prefLabel "Schedule Control"@en ;
    rdfs:comment "A control that governs the planned timing and sequencing of tasks."@en ;
    dcterms:source "ISO 16739-1:2024, IfcWorkSchedule."@en .

sscobfi:CalendarControl a owl:Class ;
    rdfs:subClassOf sscobfi:Control ;
    rdfs:label "Calendar Control"@en ;
    skos:prefLabel "Calendar Control"@en ;
    rdfs:comment "A control that defines working and non-working time patterns for task execution."@en ;
    dcterms:source "ISO 16739-1:2024, IfcWorkCalendar."@en .

sscobfi:CostControl a owl:Class ;
    rdfs:subClassOf sscobfi:Control ;
    rdfs:label "Cost Control"@en ;
    skos:prefLabel "Cost Control"@en ;
    rdfs:comment "A control that governs planned cost, budget, or cost-related constraints for a task or process."@en ;
    dcterms:source "ISO 16739-1:2024, IfcCostItem and related cost control concepts."@en .

#################################################################
# SSCO-BFI classes
#################################################################

sscobfi:AnalysisModel a owl:Class ;
    rdfs:label "Analysis Model"@en ;
    skos:prefLabel "Analysis Model"@en ;
    rdfs:comment "An analysis model representing the idealized structural analysis formulation for a project."@en ;
    dcterms:source "ISO 16739-1:2024; ISO 10303-104:2000, finite element analysis."@en .

sscobfi:SpatialStructureElement a owl:Class ;
    rdfs:label "Spatial Structure Element"@en ;
    skos:prefLabel "Spatial Structure Element"@en ;
    rdfs:comment "A spatial structural context that may contain substructures and structural elements."@en ;
    dcterms:source "ISO 16739-1:2024, IfcSpatialStructureElement."@en .

sscobfi:StructuralElement a owl:Class ;
    rdfs:label "Structural Element"@en ;
    skos:prefLabel "Structural Element"@en ;
    rdfs:comment "A structural element in the product model."@en ;
    dcterms:source "ISO 16739-1:2024, structural element concepts."@en .

sscobfi:StructuralItem a owl:Class ;
    rdfs:label "Structural Item"@en ;
    skos:prefLabel "Structural Item"@en ;
    rdfs:comment "An analysis-level structural item idealized from a structural element."@en ;
    dcterms:source "ISO 16739-1:2024; ISO 10303-104:2000, finite element idealization structures."@en .

sscobfi:MaterialDefinition a owl:Class ;
    rdfs:label "Material Definition"@en ;
    skos:prefLabel "Material Definition"@en ;
    rdfs:comment "A definition of material assigned to a structural element or item."@en ;
    dcterms:source "ISO 16739-1:2024; ISO 10303-104:2000, material definitions."@en .

sscobfi:AnalysisStep a owl:Class ;
    rdfs:label "Analysis Step"@en ;
    skos:prefLabel "Analysis Step"@en ;
    rdfs:comment "An ordered step within an analysis model."@en ;
    dcterms:source "ISO 10303-104:2000, result_analysis_step."@en .

sscobfi:Constraint a owl:Class ;
    rdfs:label "Constraint"@en ;
    skos:prefLabel "Constraint"@en ;
    rdfs:comment "A boundary condition or constraint applicable to an analysis step or structural item."@en ;
    dcterms:source "ISO 10303-104:2000; ISO 10303-108:2005, parameterization and constraints."@en .

sscobfi:AnalysisState a owl:Class ;
    rdfs:label "Analysis State"@en ;
    skos:prefLabel "Analysis State"@en ;
    rdfs:comment "An initial or final analysis state associated with a task."@en ;
    dcterms:source "ISO 10303-104:2000, model state structures."@en .

sscobfi:StateDefinition a owl:Class ;
    rdfs:label "State Definition"@en ;
    skos:prefLabel "State Definition"@en ;
    rdfs:comment "A definition describing an analysis state."@en ;
    dcterms:source "ISO 10303-104:2000, state_definition and field_variable_definition."@en .

sscobfi:AnalysisResults a owl:Class ;
    rdfs:label "Analysis Results"@en ;
    skos:prefLabel "Analysis Results"@en ;
    rdfs:comment "A set of analysis results produced by an analysis model."@en ;
    dcterms:source "ISO 10303-104:2000, finite element analysis result structures."@en .

sscobfi:AnalysisResultsStep a owl:Class ;
    rdfs:label "Analysis Results Step"@en ;
    skos:prefLabel "Analysis Results Step"@en ;
    rdfs:comment "A result subset corresponding to a particular analysis step."@en ;
    dcterms:source "ISO 10303-104:2000, result_analysis_step."@en .


# --- Structural item subclasses ---
sscobfi:LineStructuralItem a owl:Class ;
    rdfs:subClassOf sscobfi:StructuralItem ;
    rdfs:label "Line Structural Item"@en ;
    skos:prefLabel "Line Structural Item"@en ;
    rdfs:comment "An analysis-level structural item idealized as a line-based representation."@en ;
    dcterms:source "ISO 10303-104:2000, finite element idealization structures."@en .

sscobfi:SurfaceStructuralItem a owl:Class ;
    rdfs:subClassOf sscobfi:StructuralItem ;
    rdfs:label "Surface Structural Item"@en ;
    skos:prefLabel "Surface Structural Item"@en ;
    rdfs:comment "An analysis-level structural item idealized as a surface-based representation."@en ;
    dcterms:source "ISO 10303-104:2000, finite element idealization structures."@en .

sscobfi:SolidStructuralItem a owl:Class ;
    rdfs:subClassOf sscobfi:StructuralItem ;
    rdfs:label "Solid Structural Item"@en ;
    skos:prefLabel "Solid Structural Item"@en ;
    rdfs:comment "An analysis-level structural item idealized as a solid-based representation."@en ;
    dcterms:source "ISO 10303-104:2000, finite element idealization structures."@en .

# --- Analysis state subclasses ---
sscobfi:InitialAnalysisState a owl:Class ;
    rdfs:subClassOf sscobfi:AnalysisState ;
    rdfs:label "Initial Analysis State"@en ;
    skos:prefLabel "Initial Analysis State"@en ;
    rdfs:comment "An analysis state representing the initial condition of an analysis task or step."@en ;
    dcterms:source "ISO 10303-104:2000, model state structures."@en .

sscobfi:FinalAnalysisState a owl:Class ;
    rdfs:subClassOf sscobfi:AnalysisState ;
    rdfs:label "Final Analysis State"@en ;
    skos:prefLabel "Final Analysis State"@en ;
    rdfs:comment "An analysis state representing the final condition of an analysis task or step."@en ;
    dcterms:source "ISO 10303-104:2000, model state structures."@en .



#################################################################
# SSCO-SCC classes
#################################################################

sscoscc:SustainabilityAspect a owl:Class ;
    rdfs:label "Sustainability Aspect"@en ;
    skos:prefLabel "Sustainability Aspect"@en ;
    rdfs:comment "An aspect of sustainability relevant to the assessment of construction works, typically environmental, social, or economic."@en ;
    dcterms:source "ISO 15392:2019, sustainability in buildings and civil engineering works; ISO 21929-1:2011, sustainability indicators framework."@en .

sscoscc:SustainabilityIndicator a owl:Class ;
    rdfs:label "Sustainability Indicator"@en ;
    skos:prefLabel "Sustainability Indicator"@en ;
    rdfs:comment "An indicator used to assess a sustainability aspect across one or more life cycle stages."@en ;
    dcterms:source "ISO 21929-1:2011, framework for sustainability indicators and core indicators for buildings."@en .

sscoscc:LifeCycleStage a owl:Class ;
    rdfs:label "Life Cycle Stage"@en ;
    skos:prefLabel "Life Cycle Stage"@en ;
    rdfs:comment "A stage in the life cycle of a construction work to which indicators or performances may relate."@en ;
    dcterms:source "ISO 15686-1:2011, life-cycle stages; ISO 15392:2019, life cycle of construction works."@en .

sscoscc:Benchmark a owl:Class ;
    rdfs:label "Benchmark"@en ;
    skos:prefLabel "Benchmark"@en ;
    rdfs:comment "A reference level or benchmark used to interpret an indicator or criterion."@en ;
    dcterms:source "ISO 21678:2020, indicators and benchmarks; ISO 21931-2:2019, benchmarks or levels of performance."@en .

sscoscc:ComplianceRequirement a owl:Class ;
    rdfs:label "Compliance Requirement"@en ;
    skos:prefLabel "Compliance Requirement"@en ;
    rdfs:comment "A compliance obligation that shall be satisfied and may be specified by indicators and criteria."@en ;
    dcterms:source "ISO 37301:2021, compliance obligations."@en .

sscoscc:ComplianceCriterion a owl:Class ;
    rdfs:label "Compliance Criterion"@en ;
    skos:prefLabel "Compliance Criterion"@en ;
    rdfs:comment "A criterion used to assess whether a compliance requirement is satisfied."@en .

sscoscc:ComplianceCheck a owl:Class ;
    rdfs:label "Compliance Check"@en ;
    skos:prefLabel "Compliance Check"@en ;
    rdfs:comment "An activity that checks a criterion and produces a compliance result."@en .

sscoscc:ComplianceResult a owl:Class ;
    rdfs:label "Compliance Result"@en ;
    skos:prefLabel "Compliance Result"@en ;
    rdfs:comment "The result produced by a compliance check."@en .

sscoscc:Performance a owl:Class ;
    rdfs:label "Performance"@en ;
    skos:prefLabel "Performance"@en ;
    rdfs:comment "Performance relevant to sustainability assessment and related technical-functional reference conditions."@en ;
    dcterms:source "ISO 21931-1:2022, framework for assessing environmental, social and economic performance; ISO 21931-2:2019, framework for assessing environmental performance."@en .

sscoscc:SustainabilityPerformance a owl:Class ;
    rdfs:subClassOf sscoscc:Performance ;
    rdfs:label "Sustainability Performance"@en ;
    skos:prefLabel "Sustainability Performance"@en ;
    rdfs:comment "Performance related to the environmental, social, or economic assessment of a construction work."@en ;
    dcterms:source "ISO 21931-1:2022, sustainability performance framework; ISO 21931-2:2019, environmental performance framework."@en .

sscoscc:FunctionalTechnicalPerformance a owl:Class ;
    rdfs:subClassOf sscoscc:Performance ;
    rdfs:label "Functional Technical Performance"@en ;
    skos:prefLabel "Functional Technical Performance"@en ;
    rdfs:comment "Technical and functional performance considered as a reference condition for sustainability assessment."@en ;
    dcterms:source "ISO 15392:2019, technical and functional performance; ISO 21931-2:2019, technical and functional characteristics and functional equivalent."@en .

sscoscc:Nonconformity a owl:Class ;
    rdfs:label "Nonconformity"@en ;
    skos:prefLabel "Nonconformity"@en ;
    rdfs:comment "A non-fulfilment of a requirement identified during a compliance check."@en ;
    dcterms:source "ISO 9000:2015, nonconformity; ISO 37301:2021, nonconformity and corrective action."@en .


# --- Sustainability aspects ---
sscoscc:EnvironmentalAspect a owl:Class ;
    rdfs:subClassOf sscoscc:SustainabilityAspect ;
    rdfs:label "Environmental Aspect"@en ;
    skos:prefLabel "Environmental Aspect"@en ;
    rdfs:comment "A sustainability aspect related to environmental performance."@en ;
    dcterms:source "ISO 21931-1:2022; ISO 21931-2:2019."@en .

sscoscc:SocialAspect a owl:Class ;
    rdfs:subClassOf sscoscc:SustainabilityAspect ;
    rdfs:label "Social Aspect"@en ;
    skos:prefLabel "Social Aspect"@en ;
    rdfs:comment "A sustainability aspect related to social performance."@en ;
    dcterms:source "EN 16309:2014+A1:2014; ISO 21931-1:2022."@en .

sscoscc:EconomicAspect a owl:Class ;
    rdfs:subClassOf sscoscc:SustainabilityAspect ;
    rdfs:label "Economic Aspect"@en ;
    skos:prefLabel "Economic Aspect"@en ;
    rdfs:comment "A sustainability aspect related to economic performance."@en ;
    dcterms:source "ISO 21931-1:2022."@en .

# --- Sustainability indicators ---
sscoscc:EnvironmentalIndicator a owl:Class ;
    rdfs:subClassOf sscoscc:SustainabilityIndicator ;
    rdfs:label "Environmental Indicator"@en ;
    skos:prefLabel "Environmental Indicator"@en ;
    rdfs:comment "A sustainability indicator used to assess environmental performance."@en ;
    dcterms:source "ISO 21929-1:2011; ISO 21931-2:2019."@en .

sscoscc:SocialIndicator a owl:Class ;
    rdfs:subClassOf sscoscc:SustainabilityIndicator ;
    rdfs:label "Social Indicator"@en ;
    skos:prefLabel "Social Indicator"@en ;
    rdfs:comment "A sustainability indicator used to assess social performance."@en ;
    dcterms:source "EN 16309:2014+A1:2014."@en .

sscoscc:EconomicIndicator a owl:Class ;
    rdfs:subClassOf sscoscc:SustainabilityIndicator ;
    rdfs:label "Economic Indicator"@en ;
    skos:prefLabel "Economic Indicator"@en ;
    rdfs:comment "A sustainability indicator used to assess economic performance."@en ;
    dcterms:source "ISO 21931-1:2022."@en .

# --- Life cycle stages ---
sscoscc:ProductStage a owl:Class ;
    rdfs:subClassOf sscoscc:LifeCycleStage ;
    rdfs:label "Product Stage"@en ;
    skos:prefLabel "Product Stage"@en ;
    rdfs:comment "A life cycle stage covering product-related processes before construction."@en ;
    dcterms:source "ISO 15686-1:2011; ISO 15392:2019."@en .

sscoscc:ConstructionStage a owl:Class ;
    rdfs:subClassOf sscoscc:LifeCycleStage ;
    rdfs:label "Construction Stage"@en ;
    skos:prefLabel "Construction Stage"@en ;
    rdfs:comment "A life cycle stage covering on-site construction and installation processes."@en ;
    dcterms:source "ISO 15686-1:2011; ISO 15392:2019."@en .

sscoscc:UseStage a owl:Class ;
    rdfs:subClassOf sscoscc:LifeCycleStage ;
    rdfs:label "Use Stage"@en ;
    skos:prefLabel "Use Stage"@en ;
    rdfs:comment "A life cycle stage covering use, operation, maintenance, and related service life processes."@en ;
    dcterms:source "ISO 15686-1:2011; ISO 15392:2019."@en .

sscoscc:EndOfLifeStage a owl:Class ;
    rdfs:subClassOf sscoscc:LifeCycleStage ;
    rdfs:label "End-of-Life Stage"@en ;
    skos:prefLabel "End-of-Life Stage"@en ;
    rdfs:comment "A life cycle stage covering deconstruction, disposal, recovery, or recycling processes."@en ;
    dcterms:source "ISO 15686-1:2011; ISO 15392:2019."@en .

# --- Compliance result subclasses ---
sscoscc:CompliantResult a owl:Class ;
    rdfs:subClassOf sscoscc:ComplianceResult ;
    rdfs:label "Compliant Result"@en ;
    skos:prefLabel "Compliant Result"@en ;
    rdfs:comment "A compliance result indicating that the checked criterion is satisfied."@en .

sscoscc:NoncompliantResult a owl:Class ;
    rdfs:subClassOf sscoscc:ComplianceResult ;
    rdfs:label "Noncompliant Result"@en ;
    skos:prefLabel "Noncompliant Result"@en ;
    rdfs:comment "A compliance result indicating that the checked criterion is not satisfied."@en .

sscoscc:PartiallyCompliantResult a owl:Class ;
    rdfs:subClassOf sscoscc:ComplianceResult ;
    rdfs:label "Partially Compliant Result"@en ;
    skos:prefLabel "Partially Compliant Result"@en ;
    rdfs:comment "A compliance result indicating that the checked criterion is only partly satisfied."@en .

sscoscc:NotAssessableResult a owl:Class ;
    rdfs:subClassOf sscoscc:ComplianceResult ;
    rdfs:label "Not Assessable Result"@en ;
    skos:prefLabel "Not Assessable Result"@en ;
    rdfs:comment "A compliance result indicating that a valid assessment cannot be established from the available evidence."@en .




#################################################################
# SSCO-Core properties
#################################################################

sscore:hasObjective a owl:ObjectProperty ;
    rdfs:label "has objective"@en ;
    rdfs:comment "Links a project to an objective."@en ;
    rdfs:domain sscore:Project ;
    rdfs:range sscore:Objective .

sscore:isMeasuredBy a owl:ObjectProperty ;
    rdfs:label "is measured by"@en ;
    rdfs:comment "Links an objective to a metric."@en ;
    rdfs:domain sscore:Objective ;
    rdfs:range sscore:Metric .

sscore:usesClassification a owl:ObjectProperty ;
    rdfs:label "uses classification"@en ;
    rdfs:comment "Links a project to a classification system."@en ;
    rdfs:domain sscore:Project ;
    rdfs:range sscore:Classification .


sscore:hasUnitSpecification a owl:ObjectProperty ;
    rdfs:label "has unit specification"@en ;
    rdfs:comment "Links a project to the default unit specification used to interpret quantitative values in the project context."@en ;
    rdfs:domain sscore:Project ;
    rdfs:range sscore:UnitSpecification .

sscore:belongsToClassification a owl:ObjectProperty ;
    rdfs:label "belongs to classification"@en ;
    rdfs:comment "Links a classification reference to a classification."@en ;
    rdfs:domain sscore:ClassificationReference ;
    rdfs:range sscore:Classification .

sscobfi:hasTask a owl:ObjectProperty ;
    rdfs:label "has task"@en ;
    rdfs:comment "Links a structural element to a task associated with its construction or engineering work."@en ;
    rdfs:domain sscobfi:StructuralElement ;
    rdfs:range sscobfi:Task .

sscobfi:precedesTask a owl:TransitiveProperty, owl:ObjectProperty ;
    rdfs:label "precedes task"@en ;
    rdfs:comment "Defines sequence among tasks."@en ;
    rdfs:domain sscobfi:Task ;
    rdfs:range sscobfi:Task .

sscobfi:isControlledBy a owl:ObjectProperty ;
    rdfs:label "is controlled by"@en ;
    rdfs:comment "Links a task to a control."@en ;
    rdfs:domain sscobfi:Task ;
    rdfs:range sscobfi:Control .

sscobfi:allocatesResource a owl:ObjectProperty ;
    rdfs:label "allocates resource"@en ;
    rdfs:comment "Links a control to a resource."@en ;
    rdfs:domain sscobfi:Control ;
    rdfs:range sscobfi:Resource .

sscobfi:consumesResource a owl:ObjectProperty ;
    rdfs:label "consumes resource"@en ;
    rdfs:comment "Links a task to a resource it consumes."@en ;
    rdfs:domain sscobfi:Task ;
    rdfs:range sscobfi:Resource .

sscore:hasClassificationReference a owl:ObjectProperty ;
    rdfs:label "has classification reference"@en ;
    rdfs:comment "Links a structural element to a classification reference."@en ;
    rdfs:domain sscobfi:StructuralElement ;
    rdfs:range sscore:ClassificationReference .

#################################################################
# SSCO-BFI properties
#################################################################

sscobfi:containsProcess a owl:ObjectProperty ;
    rdfs:label "contains process"@en ;
    rdfs:comment "Links a spatial structure element to a process."@en ;
    rdfs:domain sscobfi:SpatialStructureElement ;
    rdfs:range sscobfi:Process .

sscobfi:containsElement a owl:ObjectProperty ;
    rdfs:label "contains element"@en ;
    rdfs:comment "Links a spatial structure element to a structural element."@en ;
    rdfs:domain sscobfi:SpatialStructureElement ;
    rdfs:range sscobfi:StructuralElement .

sscobfi:isConstructedBy a owl:ObjectProperty ;
    rdfs:label "is constructed by"@en ;
    rdfs:comment "Links a structural element to a process by which it is constructed."@en ;
