    rdfs:comment "Links an indicator to a life cycle stage."@en ;
    rdfs:domain sscoscc:SustainabilityIndicator ;
    rdfs:range sscoscc:LifeCycleStage .

sscoscc:hasBenchmark a owl:ObjectProperty ;
    rdfs:label "has benchmark"@en ;
