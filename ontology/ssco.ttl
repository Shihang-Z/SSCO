    rdfs:range sscoscc:Benchmark .

sscoscc:usesBenchmark a owl:ObjectProperty ;
    rdfs:label "uses benchmark"@en ;
    rdfs:comment "Links a compliance criterion to a benchmark."@en ;
    rdfs:domain sscoscc:ComplianceCriterion ;
    rdfs:range sscoscc:Benchmark .

sscoscc:indicatesPerformance a owl:ObjectProperty ;
    rdfs:label "indicates performance"@en ;
    rdfs:comment "Links an indicator to a performance."@en ;
    rdfs:domain sscoscc:SustainabilityIndicator ;
    rdfs:range sscoscc:Performance .

sscoscc:relatesToLifeCycleStage a owl:ObjectProperty ;
    rdfs:label "relates to life cycle stage"@en ;
    rdfs:comment "Links a performance to a life cycle stage."@en ;
    rdfs:domain sscoscc:Performance ;
    rdfs:range sscoscc:LifeCycleStage .

sscoscc:isBasedOnPerformance a owl:ObjectProperty ;
