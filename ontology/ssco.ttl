    rdfs:domain sscoscc:ComplianceCheck ;
    rdfs:range sscoscc:Performance .

sscoscc:appliesToStructuralItem a owl:ObjectProperty ;
    rdfs:label "applies to structural item"@en ;
    rdfs:comment "Relates a compliance criterion to the structural item to which it applies."@en ;
    rdfs:domain sscoscc:ComplianceCriterion ;
    rdfs:range sscobfi:StructuralItem .

sscobfi:appliesToAnalysisState a owl:ObjectProperty ;
